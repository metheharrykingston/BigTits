{
  "name": "bigtits-app",
  "private": true,
  "version": "0.1.0",
  "description": "BigTits — one Capacitor native app. React/Vite is the UI layer. Gov Copilot is /gov inside this bundle.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "cap:init": "npm run build && npx cap add android && npx cap add ios",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:sync:ios": "npm run build && npx cap sync ios && npm run ios:plugin",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npm run cap:sync:android && npx cap run android",
    "gov-api": "cd server/gov && .venv/bin/python -m uvicorn main:app --reload --host 0.0.0.0 --port 8001",
    "portal-scan": "cd scripts/portal-scanner && npm run scan",
    "android:plugin": "bash scripts/install-android-plugin.sh",
    "android:install": "bash scripts/android-fast-install.sh",
    "ios:plugin": "bash scripts/install-ios-plugin.sh",
    "vercel:deploy": "vercel --prod"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-community/text-to-speech": "^6.0.0",
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/filesystem": "^7.1.1",
    "@capacitor/ios": "^7.6.7",
    "@tailwindcss/vite": "^4.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.6.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vercel": "^54.14.2",
    "vite": "^8.0.12"
  }
}