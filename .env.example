# ── Local dev ──────────────────────────────────────────────
# Leave both empty. Vite proxies /api → http://localhost:3001

# ── Vercel (set in Vercel dashboard, NOT here) ───────────
# RAILWAY_API_URL=https://your-api.up.railway.app

# ── Optional: direct browser → Railway (skip Vercel proxy) ─
# VITE_API_URL=https://your-api.up.railway.app
# Also set CORS_ORIGINS on Railway API to include your Vercel domain.